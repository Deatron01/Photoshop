<Window x:Class="ImageProcessing.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageProcessing.WpfApp"
        Title="High-Perf Image Processor" Height="600" Width="900" Background="#1E1E1E">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <Button Content="Load Image" Command="{Binding LoadImageCommand}" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="{Binding ExecutionTime}" Foreground="#00FF00" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Operations:" Foreground="White" Margin="0,0,0,5"/>
            <Button Content="Negation" Command="{Binding NegationCommand}" Margin="0,2"/>

            <StackPanel Orientation="Horizontal" Margin="0,2">
                <Button Content="Gamma" Command="{Binding GammaCommand}" Width="150"/>
                <TextBox Text="{Binding GammaValue}" Width="40" Margin="5,0,0,0" VerticalContentAlignment="Center"/>
            </StackPanel>

            <Button Content="Log Transform" Command="{Binding LogCommand}" Margin="0,2"/>
            <Button Content="Grayscale" Command="{Binding GrayscaleCommand}" Margin="0,2"/>
            <Button Content="Show Histogram" Command="{Binding HistogramCommand}" Margin="0,2"/>
            <Button Content="Hist. Equalization" Command="{Binding HistogramEqCommand}" Margin="0,2"/>
            <Button Content="Box Filter" Command="{Binding BoxFilterCommand}" Margin="0,2"/>
            <Button Content="Gaussian Filter" Command="{Binding GaussianFilterCommand}" Margin="0,2"/>
            <Button Content="Sobel Edge" Command="{Binding SobelCommand}" Margin="0,2"/>
            <Button Content="Laplace Edge" Command="{Binding LaplaceCommand}" Margin="0,2"/>
            <Button Content="Harris Keypoints" Command="{Binding HarrisCommand}" Margin="0,2"/>
        </StackPanel>

        <Border Grid.Column="1" Margin="10" Background="#2D2D30" BorderBrush="Black" BorderThickness="1">
            <Image Source="{Binding DisplayImage}" Stretch="Uniform" />
        </Border>
    </Grid>
</Window>